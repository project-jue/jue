"""
* Phase 1 Parsing Test: Variable Declarations
* Tests variable declarations and assignments
* @phase 1
* @complexity basic
* @component parsing
"""

# Simple variable declarations
x = 1
y = 2
name = "hello"
active = True

# Multiple assignments
a = b = 10
x, y = 1, 2

# Variable expressions
result = x + y
message = "Value: " + result
total = (a * b) + (x - y)

# Reassignment
x = x + 1
y = y * 2
