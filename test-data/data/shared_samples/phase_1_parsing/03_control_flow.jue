"""
* Phase 1 Parsing Test: Control Flow Constructs
* Tests if statements and basic control flow
* @phase 1
* @complexity intermediate
* @component parsing
"""

# Simple if statement
if x > 0:
    result = "positive"

# If-else statement
if temperature > 30:
    status = "hot"
else:
    status = "moderate"

# If-elif-else chain
if score >= 90:
    grade = "A"
elif score >= 80:
    grade = "B"
elif score >= 70:
    grade = "C"
else:
    grade = "F"

# Nested if statements
if x > 0:
    if y > 0:
        quadrant = "I"
    else:
        quadrant = "IV"
else:
    if y > 0:
        quadrant = "II"
    else:
        quadrant = "III"
