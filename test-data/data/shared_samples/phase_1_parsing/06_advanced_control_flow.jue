"""
* Phase 1 Parsing Test: Advanced Control Flow
* Tests complex control flow patterns and nested structures
* @phase 1
* @complexity advanced
* @component parsing
"""

# Complex nested if-else structures
if x > 0:
    if y > 0:
        if z > 0:
            quadrant = "I"
        else:
            quadrant = "IV"
    else:
        if z > 0:
            quadrant = "II"
        else:
            quadrant = "III"
else:
    if y > 0:
        if z > 0:
            quadrant = "V"
        else:
            quadrant = "VIII"
    else:
        if z > 0:
            quadrant = "VI"
        else:
            quadrant = "VII"

# Complex elif chains with nested conditions
if score >= 90:
    grade = "A"
    if score >= 95:
        grade = "A+"
    elif score >= 93:
        grade = "A"
    else:
        grade = "A-"
elif score >= 80:
    grade = "B"
    if score >= 87:
        grade = "B+"
    elif score >= 83:
        grade = "B"
    else:
        grade = "B-"
elif score >= 70:
    grade = "C"
else:
    grade = "F"

# Complex boolean logic in conditions
if (x > 0 and y > 0) or (z > 0 and not active):
    result = "positive"
elif (x < 0 and y < 0) and (z < 0 or active):
    result = "negative"
else:
    result = "mixed"


# Complex nested control flow with functions
def evaluate_condition(a, b, c):
    if a > b:
        if b > c:
            return "a > b > c"
        elif a > c:
            return "a > c >= b"
        else:
            return "c >= a > b"
    elif b > c:
        if a > c:
            return "b > a > c"
        else:
            return "b > c >= a"
    else:
        return "c >= b >= a"


result = evaluate_condition(x, y, z)
