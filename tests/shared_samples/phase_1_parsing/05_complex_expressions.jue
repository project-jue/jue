/**
 * Phase 1 Parsing Test: Complex Expressions
 * Tests advanced expression patterns and complex operator combinations
 * @phase 1
 * @complexity intermediate
 * @component parsing
 */

// Complex nested expressions
result1 = ((1 + 2) * (3 + 4)) / (5 - (6 % 3))
result2 = (10 * (2 + 3)) + ((4 / 2) * (5 % 3))
result3 = ((a + b) * (c - d)) / (e % f)

// Complex operator precedence scenarios
complex1 = 1 + 2 * 3 - 4 / 2 + 5 % 3
complex2 = (1 + 2) * (3 - 4) / (5 + 6) % 7
complex3 = 10 / (2 + 3) * (4 - 1) + 2 % 3

// Mixed arithmetic with variables
mixed1 = x * (y + z) / (a - b) % c
mixed2 = (x + y) * (z - a) + (b / c) % d
mixed3 = x + y * z - a / b + c % d

// Complex assignment patterns
chained = a = b = c = 10 + 5 * 2
nested_assign = x = (y = (z = 1 + 2 * 3)) + 4
complex_assign = result = (x + y) * (z - (a / b)) % c